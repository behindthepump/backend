rules_version = '2';

// All data access goes through the backend API, which uses the Firebase
// Admin SDK and bypasses these rules entirely. No browser ever talks to
// Firestore directly, so everything is denied: this only closes the
// direct-access surface (the web API key is public and clients hold real
// Firebase Auth sessions via Google sign-in).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
