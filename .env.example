# Backend admin scripts read Firebase credentials from one of:
#   1. backend/serviceAccount.json  (recommended for local use; gitignored)
#   2. FIREBASE_SERVICE_ACCOUNT_BASE64 below (base64 of the key JSON; for deploys)
# Provide ONE of them. See src/config/firebase.ts.

# base64 -i serviceAccount.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Optional - only if the project can't be resolved from the credentials.
FIREBASE_PROJECT_ID=

# Port the API server listens on (default 4100). Must match the frontend's
# VITE_API_URL.
PORT=4100
